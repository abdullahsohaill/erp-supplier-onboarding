# Copy to .local/secrets/atp-cloud.env and replace values locally. Never commit that file.
ATP_CLOUD_USER=ERP_VERIFY
ATP_CLOUD_PASSWORD=replace-with-cloud-schema-password
ATP_CLOUD_DSN=replace-with-wallet-service-name_tp
ATP_CLOUD_WALLET_DIR=/absolute/path/to/.local/secrets/atp-wallet
ATP_CLOUD_WALLET_PASSWORD=replace-with-wallet-password
ATP_CLOUD_ORDS_URL=https://replace-with-managed-ords/ords/erp/supplier-onboarding/v1
